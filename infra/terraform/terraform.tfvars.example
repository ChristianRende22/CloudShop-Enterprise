aws_region       = "us-east-1"
project_name     = "cloudshop"
environment      = "dev"
ses_sender_email = "notificaciones@tudominio.com"
alert_email      = "tu-correo@ejemplo.com"

# El User Pool de Cognito lo crea este mismo Terraform (infra/terraform/cognito.tf).
# No hace falta ninguna variable para eso: despues de `terraform apply`,
# `terraform output cognito_user_pool_id` y `terraform output cognito_client_id`
# son los valores que va el frontend (frontend/.env.production).
